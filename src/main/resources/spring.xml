<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="car" class="com.stackninjas.Car">
        <property name="battery" ref="battery"/>
        <property name="engine" ref="petrolEngine"/>
<!--        <property name="engine" ref="dieselEngine"/>-->
        <property name="tyre" ref="tyre"/>
    </bean>

    <bean id="battery" class="com.stackninjas.Battery"/>
    <bean id="petrolEngine" class="com.stackninjas.PetrolEngine"/>
    <bean id="dieselEngine" class="com.stackninjas.DieselEngine"/>
    <bean id="tyre" class="com.stackninjas.Tyre"/>

</beans>